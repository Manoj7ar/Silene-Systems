# Copy to .env.local — never commit secrets

# When 1 or true: first dashboard visit auto-loads demo data if the user has no logs and no medications
# DEMO_AUTO_SEED=1

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Hosted: https://your-project.supabase.co — Local CLI: http://127.0.0.1:54321 (after `npm run sb:start`)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Legacy JWT anon key, or new publishable key (sb_publishable_...). Local: paste from `npm run sb:env` or `npm run sb:status`
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Server-only (optional; avoid in browser). Legacy service_role JWT, or new secret key (sb_secret_...)
SUPABASE_SERVICE_ROLE_KEY=

# AI insights + clinic summary: prefer Gemini when set, else Anthropic, else demo text
GEMINI_API_KEY=
# Optional — tries GEMINI_MODEL first, then gemini-1.5-flash, gemini-2.0-flash, etc.
# GEMINI_MODEL=gemini-1.5-flash

ANTHROPIC_API_KEY=

# Optional — text-to-speech (“Listen”) + speech-to-text (“Record & transcribe”)
ELEVENLABS_API_KEY=
# Optional overrides (defaults: app voice id, multilingual v2 TTS, scribe_v2 STT)
# ELEVENLABS_VOICE_ID=
# MP3 preset for /api/voice/tts (e.g. mp3_44100_128). Try mp3_22050_32 if playback fails in the browser.
# ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2
# ELEVENLABS_STT_MODEL_ID=scribe_v2
